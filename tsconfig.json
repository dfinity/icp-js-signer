{
  "compilerOptions": {
    "rootDir": ".",
    "target": "ES2022",
    "lib": ["ES2024", "DOM"],
    "module": "NodeNext",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "allowJs": false,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "lib", "**/*.test.ts"]
}
